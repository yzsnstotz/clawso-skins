    "states": {
      "idle": {
        "layerTransforms": {
          "body": {
            "translateY": 0
          },
          "fx": {
            "opacity": 0
          }
        },
        "expression": "ready"
      },
      "thinking": {
        "layerTransforms": {
          "head": {
            "rotateDeg": -4
          },
          "fx": {
            "opacity": 1
          }
        },
        "expression": "curious"
      },
      "talking": {
        "layerTransforms": {
          "mouth": {
            "scaleY": 1.5
          },
          "tail": {
            "rotateDeg": 8
          }
        },
        "expression": "speaking"
      },
      "celebrate": {
        "layerTransforms": {
          "body": {
            "translateY": -4
          },
          "tail": {
            "rotateDeg": 18
          },
          "fx": {
            "opacity": 1
          }
        },
        "expression": "celebrating"
      },
      "wince": {
        "layerTransforms": {
          "head": {
            "rotateDeg": 6
          },
          "body": {
            "translateX": -2
          },
          "fx": {
            "opacity": 0
          }
        },
        "expression": "recovering"
      }
    },
    "anchors": {
      "headCenterX": 32,
      "headTopY": 8,
