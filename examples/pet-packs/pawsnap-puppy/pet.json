        "targetLayer": "head",
        "durationMs": 620,
        "loop": false,
        "intensity": 1.1,
        "axis": "y",
        "easing": "ease-out"
      },
      {
        "id": "shake",
        "kind": "shake",
        "targetLayer": "body",
        "durationMs": 520,
        "loop": false,
        "intensity": 1.2,
        "axis": "x",
        "easing": "ease"
      },
      {
        "id": "sparkle",
        "kind": "pulse",
        "targetLayer": "fx",
        "durationMs": 760,
        "loop": false,
        "intensity": 1,
        "axis": "both",
        "easing": "ease-out"
      }
