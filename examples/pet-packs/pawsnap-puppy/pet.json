      },
      "phrases": [
        {
          "slot": "greet",
          "text": "Back on patrol.",
          "context": "default",
          "weight": 10
        },
        {
          "slot": "working",
          "text": "Sniffing through the task.",
          "context": "agent",
          "weight": 8
        },
        {
          "slot": "responding",
          "text": "I found a trail.",
          "context": "agent",
          "weight": 8
        },
        {
          "slot": "success",
