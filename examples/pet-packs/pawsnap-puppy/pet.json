        "targetLayer": "body",
        "durationMs": 1600,
        "loop": true,
        "intensity": 0.6,
        "axis": "y",
        "easing": "ease-in-out"
      },
      {
        "id": "think",
        "kind": "think",
        "targetLayer": "head",
        "durationMs": 1200,
        "loop": true,
        "intensity": 0.8,
        "axis": "both",
        "easing": "ease"
      },
      {
        "id": "speak",
        "kind": "stream",
        "targetLayer": "mouth",
        "durationMs": 480,
        "loop": true,
        "intensity": 1,
        "axis": "y",
        "easing": "ease-in-out"
      },
      {
        "id": "wag",
        "kind": "wave",
        "targetLayer": "tail",
        "durationMs": 540,
        "loop": true,
        "intensity": 1.2,
        "axis": "both",
        "easing": "ease-in-out"
      },
      {
        "id": "perk",
