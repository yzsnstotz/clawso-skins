  "content.primary": "#e9f6ff",
  "content.secondary": "#9fb6cc",
  "content.muted": "#647a93",
  "content.faint": "#3a4a5e",
  "content.on-accent": "#03040a",

  "border.subtle": "rgba(34,236,255,0.10)",
  "border.strong": "rgba(34,236,255,0.28)",
  "border.focus": "#22ecff",

  "accent.base": "#22ecff",
  "accent.hover": "#67f4ff",
  "accent.contrast": "#0bb6cc",
  "accent.surface": "rgba(34,236,255,0.12)",

  "semantic.success": "#3df5a8",
  "semantic.success-surface": "rgba(61,245,168,0.14)",
  "semantic.danger": "#ff4d8d",
  "semantic.danger-surface": "rgba(255,77,141,0.16)",
  "semantic.warning": "#ffc857",
  "semantic.warning-surface": "rgba(255,200,87,0.14)",
  "semantic.info": "#8a7bff",
  "semantic.info-surface": "rgba(138,123,255,0.16)",

  "font.display": "\"Fraunces\", \"Times New Roman\", serif",
  "font.sans": "\"Geist\", -apple-system, BlinkMacSystemFont, \"SF Pro Text\", system-ui, sans-serif",
  "font.mono": "\"Geist Mono\", ui-monospace, \"JetBrains Mono\", monospace",
  "font.cjk": "\"Noto Sans SC\", \"PingFang SC\", \"Hiragino Sans GB\", \"Microsoft YaHei\", sans-serif",

  "radius.xs": "2px",
