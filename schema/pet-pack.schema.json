                      "working",
                      "success",
                      "failure",
                      "waiting_user",
                      "hover",
                      "greet",
                      "move_left",
                      "move_right",
                      "responding",
                      "attention",
                      "summon",
                      "dismiss",
                      "sleep",
                      "impatient",
