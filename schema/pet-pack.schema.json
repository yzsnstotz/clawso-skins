                      "drag_start",
                      "drag_end",
                      "idle_variant",
                      "instruction_received",
                      "agent_planning",
                      "agent_coding",
                      "agent_testing",
                      "agent_fixing",
                      "agent_reviewing",
                      "agent_blocked",
                      "agent_done",
                      "automation_queued",
                      "automation_running",
                      "automation_waiting",
                      "automation_success",
                      "automation_failure",
                      "tool_pending",
                      "tool_streaming",
                      "tool_retrying",
                      "tool_waiting_input",
                      "tool_done",
                      "tool_error",
                      "auth_required",
                      "handoff_ready",
                      "panel_unread",
                      "panel_processing",
                      "panel_jump"
                    ]
                  }
                },
                "persona": {
                  "$ref": "#/definitions/PetPackManifest/properties/pet/anyOf/0/properties/persona"
                },
                "reactiveFx": {
                  "$ref": "#/definitions/PetPackManifest/properties/pet/anyOf/0/properties/reactiveFx"
                },
                "preview": {
                  "type": "object",
                  "properties": {
                    "png": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 240,
                      "pattern": "^(?![a-zA-Z][a-zA-Z0-9+.-]*:)(?![\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))(?!.*(?:^|[\\\\/])\\.(?:[\\\\/]|$))[^\\\\/]+(?:[\\\\/][^\\\\/]+)*$"
                    },
                    "svg": {
                      "$ref": "#/definitions/PetPackManifest/properties/pet/anyOf/1/properties/preview/properties/png"
                    },
                    "contactSheet": {
                      "$ref": "#/definitions/PetPackManifest/properties/pet/anyOf/1/properties/preview/properties/png"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "required": [
                "format",
                "id",
                "src",
                "stateMachine",
                "triggerInputs"
              ],
              "additionalProperties": false
