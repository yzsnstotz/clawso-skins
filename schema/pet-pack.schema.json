                "alignment": {
                  "type": "string",
                  "enum": [
                    "center",
                    "topLeft",
                    "topCenter",
                    "topRight",
                    "centerLeft",
                    "centerRight",
                    "bottomLeft",
                    "bottomCenter",
                    "bottomRight"
