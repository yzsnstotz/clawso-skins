                },
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9-]+$"
                },
                "src": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 240,
                  "pattern": "^(?![a-zA-Z][a-zA-Z0-9+.-]*:)(?![\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))(?!.*(?:^|[\\\\/])\\.(?:[\\\\/]|$))[^\\\\/]+(?:[\\\\/][^\\\\/]+)*\\.[Rr][Ii][Vv]$"
                },
                "artboard": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 120
                },
                "stateMachine": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 120
                },
                "fit": {
                  "type": "string",
                  "enum": [
                    "contain",
                    "cover",
                    "fill",
                    "fitWidth",
                    "fitHeight",
                    "none",
                    "scaleDown"
